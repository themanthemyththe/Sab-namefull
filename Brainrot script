-- Button creator
local function makeButton(text, y)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -20, 0, 38)
    btn.Position = UDim2.new(0, 10, 0, y)
    btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    btn.BorderSizePixel = 1
    btn.BorderColor3 = Color3.fromRGB(70, 70, 70)
    btn.TextColor3 = Color3.fromRGB(220, 220, 220)
    btn.Font = Enum.Font.Gotham
    btn.TextSize = 15
    btn.Text = text
    btn.AutoButtonColor = false
    btn.Parent = frame

    btn.MouseEnter:Connect(function()
        btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    end)

    btn.MouseLeave:Connect(function()
        btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    end)

    return btn
end

-- Buttons
local autoBtn = makeButton("Auto-Grab: " .. (autoGrabEnabled and "ON" or "OFF"), 45)
local speedBtn = makeButton("Speed Boost", 90)
local jumpBtn = makeButton("Jump Boost", 135)
local ringBtn = makeButton("Toggle Ring (" .. (CONFIG.SHOW_RING and "ON" or "OFF") .. ")", 180)

-- Button connections
autoBtn.MouseButton1Click:Connect(function()
    toggleAutoGrab()
end)

speedBtn.MouseButton1Click:Connect(function()
    if speedBoostActive then
        deactivateSpeedBoost()
    else
        activateSpeedBoost()
    end
end)

jumpBtn.MouseButton1Click:Connect(function()
    jumpBoost()
end)

ringBtn.MouseButton1Click:Connect(function()
    toggleRing()
end)

-- ===== INITIALIZATION =====
if CONFIG.SHOW_RING then
    createVisualRing()
end

