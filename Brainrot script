--===== STEAL A BRAINROT AUTO-GRAB + MOBILE MENU =====--

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local rootPart = character:WaitForChild("HumanoidRootPart")

-- ===== CONFIGURATION =====
local CONFIG = {
    -- Auto-Grab Settings
    ENABLED = true,
    GRAB_RANGE = 50,
    GRAB_SPEED = 0.5,
    
    -- Desync Settings
    DESYNC_ENABLED = true,
    DESYNC_AMOUNT = 15,
    
    -- Booster Settings
    SPEED_BOOST_ENABLED = false,
    SPEED_BOOST_VALUE = 2.5,
    JUMP_BOOST_ENABLED = false,
    JUMP_BOOST_VALUE = 75,
    
    -- Visual Settings
    SHOW_RING = true,
    RING_COLOR = Color3.fromRGB(0, 255, 100),
    RING_TRANSPARENCY = 0.5,
    
    -- Keybinds
    TOGGLE_KEY = Enum.KeyCode.E,
    SPEED_BOOST_KEY = Enum.KeyCode.LeftShift,
    JUMP_BOOST_KEY = Enum.KeyCode.Space,
    DESYNC_TOGGLE_KEY = Enum.KeyCode.R,
}

-- ===== VARIABLES =====
local autoGrabEnabled = CONFIG.ENABLED
local desyncEnabled = CONFIG.DESYNC_ENABLED
local speedBoostActive = false
local jumpBoostActive = false
local visualRing = nil
local lastGrabTime = 0
local grabCooldown = 0.1
local originalWalkSpeed = 16
local originalJumpPower = 50

-- Store original values
originalWalkSpeed = humanoid.WalkSpeed
originalJumpPower = humanoid.JumpPower

-- ===== FUNCTIONS =====

-- Create visual ring around player
local function createVisualRing()
    if visualRing and visualRing.Parent then
        visualRing:Destroy()
    end
    
    local ring = Instance.new("Part")
    ring.Shape = Enum.PartType.Cylinder
    ring.Material = Enum.Material.Neon
    ring.CanCollide = false
    ring.Anchored = false
    ring.CFrame = rootPart.CFrame * CFrame.Angles(math.pi/2, 0, 0)
    ring.Size = Vector3.new(CONFIG.GRAB_RANGE * 2, 0.2, CONFIG.GRAB_RANGE * 2)
    ring.Color = CONFIG.RING_COLOR
    ring.Transparency = CONFIG.RING_TRANSPARENCY
    ring.BrickColor = BrickColor.new("Lime green")
    
    local weld = Instance.new("WeldConstraint")
    weld.Part0 = rootPart
    weld.Part1 = ring
    weld.Parent = ring
    
    ring.Parent = Workspace
    visualRing = ring
end

-- Update ring position
local function updateRing()
    if visualRing and visualRing.Parent and CONFIG.SHOW_RING then
        visualRing.CFrame = rootPart.CFrame * CFrame.Angles(math.pi/2, 0, 0)
    end
end

-- Find nearest brainrot
local function findNearestBrainrot()
    local nearest = nil
    local nearestDistance = CONFIG.GRAB_RANGE
    
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("Model") and string.lower(obj.Name):find("brainrot") then
            local targetPart = obj:FindFirstChild("HumanoidRootPart") or obj.PrimaryPart or obj:FindFirstChild("Head") or obj:FindFirstChild("Torso")
            if targetPart then
                local distance = (targetPart.Position - rootPart.Position).Magnitude
                if distance < nearestDistance then
                    nearestDistance = distance
                    nearest = obj
                end
            end
        elseif obj:IsA("Part") and string.lower(obj.Name):find("brainrot") then
            local distance = (obj.Position - rootPart.Position).Magnitude
            if distance < nearestDistance then
                nearestDistance = distance
                nearest = obj
            end
        end
    end
    
    return nearest
end

-- Auto-grab brainrot
local function autoGrabBrainrot()
    if not autoGrabEnabled then return end
    if tick() - lastGrabTime < grabCooldown then return end
    
    local target = findNearestBrainrot()
    if not target then return end
    
    lastGrabTime = tick()
    
    local targetPart = target:FindFirstChild("HumanoidRootPart") or target.PrimaryPart or target:FindFirstChild("Head") or target:FindFirstChild("Torso")
    if not targetPart then return end
    
    local targetPosition = targetPart.Position
    
    if desyncEnabled then
        targetPosition = targetPosition + Vector3.new(
            math.random(-CONFIG.DESYNC_AMOUNT, CONFIG.DESYNC_AMOUNT),
            math.random(-CONFIG.DESYNC_AMOUNT, CONFIG.DESYNC_AMOUNT),
            math.random(-CONFIG.DESYNC_AMOUNT, CONFIG.DESYNC_AMOUNT)
        )
    end
    
    rootPart.CFrame = rootPart.CFrame:Lerp(CFrame.new(targetPosition), CONFIG.GRAB_SPEED)
end

-- Speed boost functions
local function updateSpeed()
    if CONFIG.SPEED_BOOST_ENABLED then
        humanoid.WalkSpeed = originalWalkSpeed * CONFIG.SPEED_BOOST_VALUE
        speedBoostActive = true
    else
        humanoid.WalkSpeed = originalWalkSpeed
        speedBoostActive = false
    end
end

local function toggleSpeedBoost()
    CONFIG.SPEED_BOOST_ENABLED = not CONFIG.SPEED_BOOST_ENABLED
    updateSpeed()
    speedToggleBtn.Text = "Speed Boost: " .. (CONFIG.SPEED_BOOST_ENABLED and "ON" or "OFF")
    print("Speed Boost: " .. (CONFIG.SPEED_BOOST_ENABLED and "ON ✓" or "OFF ✗"))
end

-- Jump boost functions
local function updateJump()
    if CONFIG.JUMP_BOOST_ENABLED then
        humanoid.JumpPower = CONFIG.JUMP_BOOST_VALUE
        jumpBoostActive = true
    else
        humanoid.JumpPower = originalJumpPower
        jumpBoostActive = false
    end
end

local function toggleJumpBoost()
    CONFIG.JUMP_BOOST_ENABLED = not CONFIG.JUMP_BOOST_ENABLED
    updateJump()
    jumpToggleBtn.Text = "Jump Boost: " .. (CONFIG.JUMP_BOOST_ENABLED and "ON" or "OFF")
    print("Jump Boost: " .. (CONFIG.JUMP_BOOST_ENABLED and "ON ✓" or "OFF ✗"))
end

-- Update speed value
local function updateSpeedValue(newValue)
    newValue = tonumber(newValue)
    if newValue and newValue > 0 then
        CONFIG.SPEED_BOOST_VALUE = newValue
        if CONFIG.SPEED_BOOST_ENABLED then
            humanoid.WalkSpeed = originalWalkSpeed * CONFIG.SPEED_BOOST_VALUE
        end
        speedValueLabel.Text = "Speed: " .. string.format("%.1f", CONFIG.SPEED_BOOST_VALUE) .. "x"
        print("Speed multiplier set to: " .. CONFIG.SPEED_BOOST_VALUE .. "x")
    end
end

-- Update jump value
local function updateJumpValue(newValue)
    newValue = tonumber(newValue)
    if newValue and newValue > 0 then
        CONFIG.JUMP_BOOST_VALUE = newValue
        if CONFIG.JUMP_BOOST_ENABLED then
            humanoid.JumpPower = CONFIG.JUMP_BOOST_VALUE
        end
        jumpValueLabel.Text = "Jump: " .. CONFIG.JUMP_BOOST_VALUE
        print("Jump power set to: " .. CONFIG.JUMP_BOOST_VALUE)
    end
end

-- Toggle functions
local function toggleAutoGrab()
    autoGrabEnabled = not autoGrabEnabled
    autoBtn.Text = "Auto-Grab: " .. (autoGrabEnabled and "ON" or "OFF")
    print("Auto-Grab: " .. (autoGrabEnabled and "ON ✓" or "OFF ✗"))
end

local function toggleDesync()
    desyncEnabled = not desyncEnabled
    desyncBtn.Text = "Desync: " .. (desyncEnabled and "ON" or "OFF")
    print("Desync: " .. (desyncEnabled and "ON ✓" or "OFF ✗"))
end

local function toggleRing()
    CONFIG.SHOW_RING = not CONFIG.SHOW_RING
    ringBtn.Text = "Ring: " .. (CONFIG.SHOW_RING and "ON" or "OFF")
    
    if CONFIG.SHOW_RING then
        createVisualRing()
        print("Ring: ON ✓")
    else
        if visualRing then
            visualRing:Destroy()
            visualRing = nil
        end
        print("Ring: OFF ✗")
    end
end

-- ===== INPUT HANDLING =====
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == CONFIG.TOGGLE_KEY then
        toggleAutoGrab()
    elseif input.KeyCode == CONFIG.DESYNC_TOGGLE_KEY then
        toggleDesync()
    elseif input.KeyCode == CONFIG.SPEED_BOOST_KEY then
        -- Temporary speed boost while holding
        if not CONFIG.SPEED_BOOST_ENABLED then
            humanoid.WalkSpeed = originalWalkSpeed * CONFIG.SPEED_BOOST_VALUE
            speedBoostActive = true
        end
    elseif input.KeyCode == CONFIG.JUMP_BOOST_KEY then
        -- Temporary jump boost
        if not CONFIG.JUMP_BOOST_ENABLED then
            local oldJump = humanoid.JumpPower
            humanoid.JumpPower = CONFIG.JUMP_BOOST_VALUE
            humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
            task.wait(0.1)
            humanoid.JumpPower = oldJump
        end
    end
end)

UserInputService.InputEnded:Connect(function(input, gameProcessed)
    if input.KeyCode == CONFIG.SPEED_BOOST_KEY then
        -- Reset speed when key released
        if not CONFIG.SPEED_BOOST_ENABLED then
            humanoid.WalkSpeed = originalWalkSpeed
            speedBoostActive = false
        end
    end
end)

-- ===== MAIN LOOP =====
RunService.RenderStepped:Connect(function()
    if not character or not character.Parent then return end
    
    if CONFIG.SHOW_RING and visualRing then
        updateRing()
    end
    
    if autoGrabEnabled then
        autoGrabBrainrot()
    end
end)

-- Handle character respawn
player.CharacterAdded:Connect(function(newCharacter)
    character = newCharacter
    humanoid = character:WaitForChild("Humanoid")
    rootPart = character:WaitForChild("HumanoidRootPart")
    
    originalWalkSpeed = humanoid.WalkSpeed
    originalJumpPower = humanoid.JumpPower
    
    -- Restore states
    updateSpeed()
    updateJump()
    
    task.wait(1)
    if CONFIG.SHOW_RING then
        createVisualRing()
    end
    
    print("Script reinitialized on respawn")
end)

