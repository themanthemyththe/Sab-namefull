--===== FIXED STEAL A BRAINROT AUTO-GRAB + MOBILE MENU =====--

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid", 5)
local rootPart = character:WaitForChild("HumanoidRootPart", 5)

if not humanoid or not rootPart then
    warn("Failed to find humanoid/rootpart")
    return
end

-- ===== CONFIGURATION =====
local CONFIG = {
    ENABLED = true,
    GRAB_RANGE = 45,           -- lowered a bit so you have to get closer
    GRAB_TELEPORT_THRESHOLD = 12,  -- only teleport when closer than this
    GRAB_LERP_SPEED = 0.18,    -- 0–1 (lower = slower/smoother but less snappy)

    DESYNC_ENABLED = true,
    DESYNC_AMOUNT = 18,

    SPEED_BOOST_ENABLED = false,
    SPEED_BOOST_VALUE = 4.2,   -- most games need >3–5 to feel faster

    JUMP_BOOST_ENABLED = false,
    JUMP_BOOST_VALUE = 85,

    SHOW_RING = true,
    RING_COLOR = Color3.fromRGB(0, 255, 100),
    RING_TRANSPARENCY = 0.6,

    -- Keybinds (change if needed)
    TOGGLE_AUTO_GRAB_KEY = Enum.KeyCode.E,
    TOGGLE_SPEED_KEY    = Enum.KeyCode.LeftShift,
    TOGGLE_JUMP_KEY     = Enum.KeyCode.RightShift,   -- changed so no conflict with jump
    TOGGLE_DESYNC_KEY   = Enum.KeyCode.R,
}

-- ===== VARIABLES =====
local autoGrabEnabled   = CONFIG.ENABLED
local desyncEnabled     = CONFIG.DESYNC_ENABLED
local visualRing        = nil
local lastGrabTime      = 0
local grabCooldown      = 0.12

local originalWalkSpeed = humanoid.WalkSpeed
local originalJumpPower = humanoid.JumpPower

-- ===== FUNCTIONS =====

local function createVisualRing()
    if visualRing then visualRing:Destroy() end

    local ring = Instance.new("Part")
    ring.Shape        = Enum.PartType.Cylinder
    ring.Material     = Enum.Material.Neon
    ring.CanCollide   = false
    ring.Anchored     = false
    ring.Transparency = CONFIG.RING_TRANSPARENCY
    ring.Color        = CONFIG.RING_COLOR
    ring.Size         = Vector3.new(CONFIG.GRAB_RANGE*2, 0.3, CONFIG.GRAB_RANGE*2)
    ring.CFrame       = rootPart.CFrame * CFrame.Angles(math.pi/2, 0, 0)

    local weld = Instance.new("WeldConstraint")
    weld.Part0 = rootPart
    weld.Part1 = ring
    weld.Parent = ring

    ring.Parent = Workspace
    visualRing = ring
end

local function updateRing()
    if visualRing and visualRing.Parent and CONFIG.SHOW_RING then
        visualRing.CFrame = rootPart.CFrame * CFrame.Angles(math.pi/2, 0, 0)
    end
end

local function findNearestBrainrot()
    local nearest, minDist = nil, CONFIG.GRAB_RANGE

    for _, obj in Workspace:GetDescendants() do
        if not obj:IsDescendantOf(character) then
            local nameLower = string.lower(obj.Name)
            if nameLower:find("brainrot") then
                local part = obj:IsA("Model") and (
                    obj:FindFirstChild("HumanoidRootPart") or
                    obj.PrimaryPart or
                    obj:FindFirstChild("Head") or
                    obj:FindFirstChild("Torso")
                ) or (obj:IsA("BasePart") and obj)

                if part then
                    local dist = (part.Position - rootPart.Position).Magnitude
                    if dist < minDist then
                        minDist = dist
                        nearest = part
                    end
                end
            end
        end
    end
    return nearest
end

local function tryGrabBrainrot()
    if not autoGrabEnabled then return end
    if tick() - lastGrabTime < grabCooldown then return end

    local targetPart = findNearestBrainrot()
    if not targetPart then return end

    lastGrabTime = tick()

    local targetPos = targetPart.Position
    if desyncEnabled then
        targetPos += Vector3.new(
            math.random(-CONFIG.DESYNC_AMOUNT, CONFIG.DESYNC_AMOUNT),
            math.random(-CONFIG.DESYNC_AMOUNT/2, CONFIG.DESYNC_AMOUNT/2),
            math.random(-CONFIG.DESYNC_AMOUNT, CONFIG.DESYNC_AMOUNT)
        )
    end

    local dist = (targetPos - rootPart.Position).Magnitude
    if dist <= CONFIG.GRAB_TELEPORT_THRESHOLD then
        -- small lerp only when close → prevents total lock
        rootPart.CFrame = rootPart.CFrame:Lerp(CFrame.new(targetPos), CONFIG.GRAB_LERP_SPEED)
    end
    -- else do nothing → player can walk normally until close
end

-- Speed / Jump management (with anti-reset attempt)
local speedResetConnection

local function updateSpeed()
    if speedResetConnection then
        speedResetConnection:Disconnect()
        speedResetConnection = nil
    end

    if CONFIG.SPEED_BOOST_ENABLED then
        humanoid.WalkSpeed = originalWalkSpeed * CONFIG.SPEED_BOOST_VALUE

        -- Re-apply every \~0.2s because many games reset it
        speedResetConnection = RunService.Heartbeat:Connect(function()
            if humanoid and humanoid.Parent then
                humanoid.WalkSpeed = originalWalkSpeed * CONFIG.SPEED_BOOST_VALUE
            end
        end)
    else
        humanoid.WalkSpeed = originalWalkSpeed
    end
end

local function updateJump()
    humanoid.JumpPower = CONFIG.JUMP_BOOST_ENABLED and CONFIG.JUMP_BOOST_VALUE or originalJumpPower
end

-- ===== TOGGLES =====
local function toggleAutoGrab()
    autoGrabEnabled = not autoGrabEnabled
    autoBtn.Text = "Auto-Grab: " .. (autoGrabEnabled and "ON" or "OFF")
end

local function toggleDesync()
    desyncEnabled = not desyncEnabled
    desyncBtn.Text = "Desync: " .. (desyncEnabled and "ON" or "OFF")
end

local function toggleRing()
    CONFIG.SHOW_RING = not CONFIG.SHOW_RING
    ringBtn.Text = "Ring: " .. (CONFIG.SHOW_RING and "ON" or "OFF")

    if CONFIG.SHOW_RING then
        createVisualRing()
    else
        if visualRing then visualRing:Destroy() visualRing = nil end
    end
end

local function toggleSpeed()
    CONFIG.SPEED_BOOST_ENABLED = not CONFIG.SPEED_BOOST_ENABLED
    updateSpeed()
    speedToggleBtn.Text = "Speed Boost: " .. (CONFIG.SPEED_BOOST_ENABLED and "ON" or "OFF")
end

local function toggleJump()
    CONFIG.JUMP_BOOST_ENABLED = not CONFIG.JUMP_BOOST_ENABLED
    updateJump()
    jumpToggleBtn.Text = "Jump Boost: " .. (CONFIG.JUMP_BOOST_ENABLED and "ON" or "OFF")
end

-- ===== INPUT =====
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end

    local key = input.KeyCode
    if     key == CONFIG.TOGGLE_AUTO_GRAB_KEY then toggleAutoGrab()
    elseif key == CONFIG.TOGGLE_DESYNC_KEY    then toggleDesync()
    elseif key == CONFIG.TOGGLE_SPEED_KEY     then toggleSpeed()
    elseif key == CONFIG.TOGGLE_JUMP_KEY      then toggleJump()
    end
end)

-- ===== MAIN LOOP =====
RunService.RenderStepped:Connect(function()
    if not character or not character.Parent then return end

    updateRing()
    tryGrabBrainrot()
end)

-- ===== CHARACTER RESPAWN =====
player.CharacterAdded:Connect(function(newChar)
    character = newChar
    humanoid = newChar:WaitForChild("Humanoid", 8)
    rootPart  = newChar:WaitForChild("HumanoidRootPart", 8)

    if not humanoid or not rootPart then return end

    originalWalkSpeed = humanoid.WalkSpeed
    originalJumpPower = humanoid.JumpPower

    updateSpeed()
    updateJump()

    task.wait(0.6)
    if CONFIG.SHOW_RING then createVisualRing() end
end)

