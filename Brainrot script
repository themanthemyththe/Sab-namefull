--[[
    🧠 BRAINROT HACK (Nameless Admin Style)
    Fully mobile-optimized | Touch-friendly toggles
    Features:
    • Auto-Grab (with Desync)
    • Speed Boost (toggle + multiplier)
    • Jump Boost (toggle + power)
    • Visual Ring (non-blocking)
]]

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer

-- Wait for character
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local rootPart = character:WaitForChild("HumanoidRootPart")

-- ===== SETTINGS =====
local Settings = {
    AutoGrab = true,
    Desync = true,
    SpeedBoost = false,
    JumpBoost = false,
    ShowRing = true,
    GrabRange = 50,
    GrabSpeed = 0.5,
    DesyncAmount = 15,
    SpeedMultiplier = 2.5,
    JumpPower = 75,
}

-- Store original stats
local baseWalkSpeed = humanoid.WalkSpeed
local baseJumpPower = humanoid.JumpPower
local baseJumpHeight = humanoid.JumpHeight

-- Runtime vars
local lastGrabTime = 0
local grabCooldown = 0.1
local ringPart = nil
local ringMotor = nil

-- ===== CORE FUNCTIONS =====

local function findNearestBrainrot()
    local nearest, nearestDist = nil, Settings.GrabRange
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") and string.lower(obj.Name):find("brainrot") then
            local dist = (obj.Position - rootPart.Position).Magnitude
            if dist < nearestDist then nearestDist = dist; nearest = obj end
        elseif obj:IsA("Model") then
            local prim = obj.PrimaryPart or obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Head") or obj:FindFirstChild("Torso")
            if prim and string.lower(obj.Name):find("brainrot") then
                local dist = (prim.Position - rootPart.Position).Magnitude
                if dist < nearestDist then nearestDist = dist; nearest = prim end
            end
        end
    end
    return nearest
end

local function applySpeedBoost()
    humanoid.WalkSpeed = Settings.SpeedBoost and (baseWalkSpeed * Settings.SpeedMultiplier) or baseWalkSpeed
end

local function applyJumpBoost()
    if Settings.JumpBoost then
        humanoid.JumpPower = Settings.JumpPower
        humanoid.JumpHeight = Settings.JumpPower / 5
    else
        humanoid.JumpPower = baseJumpPower
        humanoid.JumpHeight = baseJumpHeight
    end
end

local function updateRing()
    if Settings.ShowRing then
        if not ringPart then
            ringPart = Instance.new("Part")
            ringPart.Name = "BrainrotRing"
            ringPart.Shape = Enum.PartType.Cylinder
            ringPart.Material = Enum.Material.Neon
            ringPart.Color = Color3.fromRGB(0, 255, 100)
            ringPart.Transparency = 0.5
            ringPart.Size = Vector3.new(Settings.GrabRange * 2, 0.2, Settings.GrabRange * 2)
            ringPart.CanCollide = false; ringPart.CanQuery = false; ringPart.CanTouch = false
            ringPart.Anchored = false
            ringPart.Parent = Workspace

            ringMotor = Instance.new("Motor6D")
            ringMotor.Part0 = rootPart; ringMotor.Part1 = ringPart
            ringMotor.C0 = CFrame.new(0,0,0) * CFrame.Angles(math.pi/2,0,0)
            ringMotor.Parent = rootPart
        end
    else
        if ringPart then ringPart:Destroy(); ringPart = nil end
        if ringMotor then ringMotor:Destroy(); ringMotor = nil end
    end
end

local function autoGrab()
    if not Settings.AutoGrab then return end
    if tick() - lastGrabTime < grabCooldown then return end
    local targetPart = findNearestBrainrot()
    if not targetPart then return end
    lastGrabTime = tick()
    local targetPos = targetPart.Position
    if Settings.Desync then
        targetPos = targetPos + Vector3.new(
            math.random(-Settings.DesyncAmount, Settings.DesyncAmount),
            math.random(-Settings.DesyncAmount, Settings.DesyncAmount),
            math.random(-Settings.DesyncAmount, Settings.DesyncAmount)
        )
    end
    rootPart.CFrame = rootPart.CFrame:Lerp(CFrame.new(targetPos), Settings.GrabSpeed)
end

-- Respawn handling
player.CharacterAdded:Connect(function(newChar)
    character = newChar
    humanoid = character:WaitForChild("Humanoid")
    rootPart = character:WaitForChild("HumanoidRootPart")
    baseWalkSpeed = humanoid.WalkSpeed
    baseJumpPower = humanoid.JumpPower
    baseJumpHeight = humanoid.JumpHeight
    applySpeedBoost(); applyJumpBoost()
    if ringPart then ringPart:Destroy(); ringPart = nil end
    if ringMotor then ringMotor:Destroy(); ringMotor = nil end
    if Settings.ShowRing then task.wait(1); updateRing() end
end)

-- Main loop
RunService.RenderStepped:Connect(function()
    if character and character.Parent then autoGrab() end
end)

-- Optional keybinds (still work but not needed on mobile)
UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.E then
        Settings.AutoGrab = not Settings.AutoGrab
        if autoBtn then autoBtn.Text = "🤖 AUTO-GRAB " .. (Settings.AutoGrab and "ON" or "OFF") end
    elseif input.KeyCode == Enum.KeyCode.R then
        Settings.Desync = not Settings.Desync
        if desyncBtn then desyncBtn.Text = "🌀 DESYNC " .. (Settings.Desync and "ON" or "OFF") end
    elseif input.KeyCode == Enum.KeyCode.LeftShift then
        if not Settings.SpeedBoost then humanoid.WalkSpeed = baseWalkSpeed * Settings.SpeedMultiplier end
    elseif input.KeyCode == Enum.KeyCode.Space then
        if Settings.JumpBoost then
            humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
        else
            local oldP, oldH = humanoid.JumpPower, humanoid.JumpHeight
            humanoid.JumpPower = Settings.JumpPower
            humanoid.JumpHeight = Settings.JumpPower / 5
            humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
            task.wait(0.2)
            humanoid.JumpPower, humanoid.JumpHeight = oldP, oldH
        end
    end
end)
UserInputService.InputEnded:Connect(function(input, gp)
    if input.KeyCode == Enum.KeyCode.LeftShift and not Settings.SpeedBoost then
        humanoid.WalkSpeed = baseWalkSpeed
    end
end)

