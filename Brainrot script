-- Helper to create toggle buttons (big, touch-friendly)
local yPos = 50
local function makeToggle(text, settingKey)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -20, 0, 45)
    btn.Position = UDim2.new(0, 10, 0, yPos)
    btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    btn.BorderSizePixel = 1
    btn.BorderColor3 = Color3.fromRGB(0, 255, 100)
    btn.TextColor3 = Color3.fromRGB(220, 220, 220)
    btn.Font = Enum.Font.Gotham
    btn.TextSize = 16
    btn.Text = text .. ": " .. (Settings[settingKey] and "ON" or "OFF")
    btn.Parent = frame

    btn.MouseEnter:Connect(function() btn.BackgroundColor3 = Color3.fromRGB(50,50,50) end)
    btn.MouseLeave:Connect(function() btn.BackgroundColor3 = Color3.fromRGB(30,30,30) end)

    btn.MouseButton1Click:Connect(function()
        Settings[settingKey] = not Settings[settingKey]
        btn.Text = text .. ": " .. (Settings[settingKey] and "ON" or "OFF")
        if settingKey == "SpeedBoost" then applySpeedBoost()
        elseif settingKey == "JumpBoost" then applyJumpBoost()
        elseif settingKey == "ShowRing" then updateRing() end
        print(text, Settings[settingKey])
    end)
    return btn
end

autoBtn = makeToggle("🤖 Auto-Grab", "AutoGrab"); yPos = yPos + 50
desyncBtn = makeToggle("🌀 Desync", "Desync"); yPos = yPos + 50
ringBtn = makeToggle("🔮 Ring", "ShowRing"); yPos = yPos + 50
speedToggleBtn = makeToggle("⚡ Speed Boost", "SpeedBoost"); yPos = yPos + 50
jumpToggleBtn = makeToggle("🦘 Jump Boost", "JumpBoost"); yPos = yPos + 50

-- Helper to create value input fields
local function makeValueInput(labelText, settingKey, suffix, minVal)
    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(1, -20, 0, 80)
    bg.Position = UDim2.new(0, 10, 0, yPos)
    bg.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    bg.BorderSizePixel = 1
    bg.BorderColor3 = Color3.fromRGB(0, 255, 100)
    bg.Parent = frame

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 0, 30)
    label.BackgroundTransparency = 1
    label.Text = labelText .. ": " .. Settings[settingKey] .. (suffix or "")
    label.TextColor3 = Color3.fromRGB(0, 255, 100)
    label.Font = Enum.Font.Gotham
    label.TextSize = 16
    label.Parent = bg

    local box = Instance.new("TextBox")
    box.Size = UDim2.new(0.7, -5, 0, 35)
    box.Position = UDim2.new(0, 5, 0, 35)
    box.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    box.BorderSizePixel = 1
    box.BorderColor3 = Color3.fromRGB(0, 255, 100)
    box.TextColor3 = Color3.fromRGB(255,255,255)
    box.PlaceholderColor3 = Color3.fromRGB(120,120,120)
    box.PlaceholderText = "Enter number"
    box.Font = Enum.Font.Gotham
    box.TextSize = 16
    box.ClearTextOnFocus = false
    box.Parent = bg

    local setBtn = Instance.new("TextButton")
    setBtn.Size = UDim2.new(0.3, -5, 0, 35)
    setBtn.Position = UDim2.new(0.7, 0, 0, 35)
    setBtn.BackgroundColor3 = Color3.fromRGB(0,100,50)
    setBtn.BorderSizePixel = 0
    setBtn.Text = "SET"
    setBtn.TextColor3 = Color3.fromRGB(255,255,255)
    setBtn.Font = Enum.Font.GothamBold
    setBtn.TextSize = 16
    setBtn.Parent = bg

    setBtn.MouseButton1Click:Connect(function()
        local val = tonumber(box.Text)
        if val and (not minVal or val >= minVal) then
            Settings[settingKey] = val
            label.Text = labelText .. ": " .. val .. (suffix or "")
            box.Text = ""
            if settingKey == "SpeedMultiplier" then applySpeedBoost()
            elseif settingKey == "JumpPower" then applyJumpBoost() end
        else
            box.Text = "Invalid!"
            task.wait(1)
            box.Text = ""
        end
    end)

    return label
end

yPos = yPos + 10
speedValLabel = makeValueInput("Speed Multiplier", "SpeedMultiplier", "x", 0.1)
yPos = yPos + 90
jumpValLabel = makeValueInput("Jump Power", "JumpPower", "", 1)

-- Initialize
if Settings.ShowRing then
    task.wait(0.5)
    updateRing()
end
applySpeedBoost()
applyJumpBoost()

print("===== BRAINROT CONTROLLER READY =====")
print("✅ All toggles work via touch")
print("✅ Speed/Jump changers work")
