-- Create toggle button function
local function createToggleButton(text, y, startState)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -20, 0, 35)
    btn.Position = UDim2.new(0, 10, 0, y)
    btn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    btn.BorderSizePixel = 1
    btn.BorderColor3 = Color3.fromRGB(0, 255, 100)
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.Gotham
    btn.TextSize = 14
    btn.Text = text .. ": " .. (startState and "ON" or "OFF")
    btn.Parent = frame
    
    btn.MouseEnter:Connect(function()
        btn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    end)
    btn.MouseLeave:Connect(function()
        btn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    end)
    
    return btn
end

-- Create value control function
local function createValueControl(name, y, value, callback, suffix)
    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(1, -20, 0, 70)
    bg.Position = UDim2.new(0, 10, 0, y)
    bg.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    bg.BorderSizePixel = 1
    bg.BorderColor3 = Color3.fromRGB(0, 255, 100)
    bg.Parent = frame
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 0, 25)
    label.BackgroundTransparency = 1
    label.Text = name .. ": " .. value .. (suffix or "")
    label.TextColor3 = Color3.fromRGB(0, 255, 100)
    label.Font = Enum.Font.Gotham
    label.TextSize = 14
    label.Parent = bg
    
    local textbox = Instance.new("TextBox")
    textbox.Size = UDim2.new(0.7, -5, 0, 30)
    textbox.Position = UDim2.new(0, 5, 0, 30)
    textbox.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    textbox.BorderSizePixel = 1
    textbox.BorderColor3 = Color3.fromRGB(0, 255, 100)
    textbox.TextColor3 = Color3.fromRGB(255, 255, 255)
    textbox.PlaceholderColor3 = Color3.fromRGB(150, 150, 150)
    textbox.PlaceholderText = "Enter value..."
    textbox.Font = Enum.Font.Gotham
    textbox.TextSize = 14
    textbox.ClearTextOnFocus = false
    textbox.Parent = bg
    
    local setBtn = Instance.new("TextButton")
    setBtn.Size = UDim2.new(0.3, -5, 0, 30)
    setBtn.Position = UDim2.new(0.7, 0, 0, 30)
    setBtn.BackgroundColor3 = Color3.fromRGB(0, 100, 50)
    setBtn.BorderSizePixel = 0
    setBtn.Text = "SET"
    setBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    setBtn.Font = Enum.Font.GothamBold
    setBtn.TextSize = 14
    setBtn.Parent = bg
    
    setBtn.MouseButton1Click:Connect(function()
        local newValue = tonumber(textbox.Text)
        if newValue then
            callback(newValue)
            label.Text = name .. ": " .. newValue .. (suffix or "")
            textbox.Text = ""
        end
    end)
    
    return label
end

